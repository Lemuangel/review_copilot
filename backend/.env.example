# 大模型 API Key（必填）
MODEL_API_KEY=your_deepseek_api_key_here

# 大模型 Base URL（DeepSeek 默认地址，注意需含 /v1）
MODEL_BASE_URL=https://api.deepseek.com/v1

# 模型名称
MODEL_NAME=deepseek-chat

# ========== MySQL 数据库 ==========
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=ai_review_copilot

# 或者直接设置完整连接串（优先级更高）：
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/ai_review_copilot

# 调试模式
DEBUG=false

# 文件上传最大大小（MB）
MAX_UPLOAD_SIZE_MB=10

# AI 生成参数
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.3
